// Prisma schema for BrightPath Tutoring
// Uses PostgreSQL via the DATABASE_URL environment variable

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Student {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  createdAt DateTime @default(now())
}
